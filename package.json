{
  "name": "ai-travel-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "analyze:bundle": "cross-env ANALYZE_BUNDLE=true vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "lhci autorun",
    "server": "npm --prefix admin-api-server start",
    "server:dev": "npm --prefix admin-api-server run dev",
    "server:install": "npm --prefix admin-api-server install",
    "quality:check": "npm run lint && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "leaflet": "^1.9.4",
    "motion-v": "^2.3.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}

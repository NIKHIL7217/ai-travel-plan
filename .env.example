# Required
VITE_GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Optional secure backend (admin-api-server). When set, AI chat + trip storage
# route through the server so the Gemini key stays server-side (recommended).
# VITE_API_BASE_URL=http://localhost:8787

# Recommended live data providers
VITE_GOOGLE_MAPS_API_KEY=PASTE_YOUR_GOOGLE_MAPS_API_KEY_HERE
VITE_OPENWEATHER_API_KEY=PASTE_YOUR_OPENWEATHER_API_KEY_HERE
VITE_TOMTOM_API_KEY=PASTE_YOUR_TOMTOM_API_KEY_HERE

# Firebase (optional, required for cloud auth + cloud trip persistence)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Behavior flags
# true  -> enforce live-only behavior and avoid static fallback content where policy is active
# false -> allow fallback logic in relevant paths
VITE_REAL_DATA_ONLY=true

# true  -> enforce no-mock policy globally (recommended)
# false -> allow demo/mock paths where implemented
VITE_NO_MOCK_DATA_POLICY=true

# Only effective when VITE_NO_MOCK_DATA_POLICY=false
VITE_DEMO_MODE=false

# Logging verbosity: debug | info | warn | error | off
VITE_LOG_LEVEL=info

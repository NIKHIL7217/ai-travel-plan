# Server runtime
PORT=8787

# Comma-separated list of allowed browser origins (Vite dev server, prod site)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Gemini key lives ONLY here on the server. It is never sent to the browser.
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Gemini model
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional live travel data keys for server-side proxying
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=

# Optional live proxy cache controls
LIVE_PROXY_CACHE_ENABLED=true
LIVE_PROXY_CACHE_MAX_ENTRIES=800
LIVE_PROXY_CACHE_TTL_GEOCODE_MS=21600000
LIVE_PROXY_CACHE_TTL_ROUTE_MS=7200000
LIVE_PROXY_CACHE_TTL_PLACES_MS=1200000
LIVE_PROXY_CACHE_TTL_WEATHER_MS=600000
